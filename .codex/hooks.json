{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/LENOVO/AppData/Local/Python/pythoncore-3.14-64/Scripts/code-review-graph.exe update --skip-flows",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "C:/Users/LENOVO/AppData/Local/Python/pythoncore-3.14-64/Scripts/graphify.exe update .",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/LENOVO/AppData/Local/Python/pythoncore-3.14-64/Scripts/code-review-graph.exe status",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "C:/Users/LENOVO/AppData/Local/Python/pythoncore-3.14-64/Scripts/graphify.exe update . && python E:/AILearningPath/.claude/graphify-obsidian-sync.py",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
