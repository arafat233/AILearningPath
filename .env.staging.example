# Staging environment template
# Copy this file: cp .env.staging.example .env.staging
# Fill in real values before running docker compose -f docker-compose.staging.yml up -d
#
# MONGO_URI and REDIS_URL are set directly in docker-compose.staging.yml
# using the staging container names — you do NOT need to set them here.
# All other vars below are injected into the api container via env_file.

# ── Core — REQUIRED ──────────────────────────────────────────────────
# REQUIRED
JWT_SECRET=CHANGE_ME_STAGING_jwt_secret_min_32_chars
# REQUIRED
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# REQUIRED
FRONTEND_URL=http://staging.stellaredu.in

# ── Server ───────────────────────────────────────────────────────────
# OPTIONAL — overridden by docker-compose.staging.yml; shown for reference
PORT=5000
# OPTIONAL — overridden by docker-compose.staging.yml; shown for reference
NODE_ENV=staging

# ── AI Model ─────────────────────────────────────────────────────────
# OPTIONAL — which Claude model to use in staging
CLAUDE_MODEL=claude-haiku-4-5-20251001
# OPTIONAL — monthly token cap (lower than prod to control costs)
MONTHLY_TOKEN_BUDGET=1000000

# ── URLs ─────────────────────────────────────────────────────────────
# OPTIONAL — used by backend for building callback and email links
BACKEND_URL=http://staging.stellaredu.in
# OPTIONAL
SITE_URL=http://staging.stellaredu.in
# OPTIONAL — injected into frontend build (not used by the API container)
VITE_API_URL=http://staging.stellaredu.in/api

# ── Google OAuth ─────────────────────────────────────────────────────
# REQUIRED if Google login is enabled in staging
# Create a separate OAuth client for staging in Google Cloud Console:
#   https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: $BACKEND_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Razorpay (payments) ───────────────────────────────────────────────
# OPTIONAL — use Razorpay test keys (rzp_test_...) in staging; never live keys
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
# Get from Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# ── Email (Resend) ────────────────────────────────────────────────────
# OPTIONAL — leave blank to disable email sending in staging
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM="Stellar Staging <noreply@staging.stellaredu.in>"

# ── Email (SMTP fallback) ─────────────────────────────────────────────
# OPTIONAL — used only if RESEND_API_KEY is not set
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Stellar Staging <noreply@staging.stellaredu.in>"

# ── Web Push / PWA notifications ─────────────────────────────────────
# OPTIONAL — generate staging-specific keys:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_EMAIL=mailto:admin@stellaredu.in

# ── Company Internal Dashboard ────────────────────────────────────────
# OPTIONAL — leave unset to disable the /company-login dashboard in staging
COMPANY_ADMIN_EMAIL=admin-staging@stellaredu.in
COMPANY_ADMIN_PASSWORD=CHANGE_ME
COMPANY_JWT_SECRET=CHANGE_ME_staging_company_jwt_secret

# ── Error monitoring (Sentry) ─────────────────────────────────────────
# OPTIONAL — leave empty to disable; set to a staging Sentry DSN if desired
SENTRY_DSN=

# ── Database backup ───────────────────────────────────────────────────
# OPTIONAL — staging backups; usually not needed but kept for completeness
BACKUP_DIR=./backups-staging
BACKUP_RETAIN_DAYS=3
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=backups-staging
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# ── Clerk (legacy — not used if Google OAuth is active) ──────────────
# OPTIONAL
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
