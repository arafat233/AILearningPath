# ── Required — server will not start without these ─────────────────
MONGO_URI=mongodb://localhost:27017/ai_learning
JWT_SECRET=change_this_to_a_long_random_string
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional — defaults shown ───────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Redis — required in production for multi-instance session safety ─
REDIS_URL=redis://localhost:6379

# ── Resend (preferred email provider) ────────────────────────────────
# Get key from: https://resend.com/api-keys
# Add verified domain in Resend dashboard (DNS: DKIM + SPF + DMARC) before sending
RESEND_API_KEY=re_...
RESEND_FROM="AILearn <noreply@yourdomain.com>"

# ── SMTP / nodemailer (fallback if RESEND_API_KEY is not set) ────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AILearn <noreply@yourdomain.com>"

# ── Clerk (auth integration) ──────────────────────────────────────────
# Get keys from: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Google OAuth (passport-google-oauth20) ────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must include: $BACKEND_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
BACKEND_URL=http://localhost:5001

# ── Razorpay (payment / subscription) ────────────────────────────────
# Get keys from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) during development
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get from Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Error monitoring (Sentry) ────────────────────────────────────────
# Create project at https://sentry.io → Settings → Projects → DSN
# Leave empty in dev to disable; set in production for automatic error capture
SENTRY_DSN=

# ── Web Push / PWA notifications ─────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourdomain.com
