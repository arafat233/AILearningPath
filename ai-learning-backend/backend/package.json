    "seed:science-physics-content": "node config/seedSciencePhysicsContent.js",
    "seed:science-chemistry-questions": "node config/seedScienceChemistryQuestions.js",
    "seed:science-biology-questions": "node config/seedScienceBiologyQuestions.js",
    "seed:science-physics-questions": "node config/seedSciencePhysicsQuestions.js",
