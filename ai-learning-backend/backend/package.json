  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clerk/backend": "^3.4.1",
    "@sentry/node": "^10.51.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "razorpay": "^2.9.6",
    "resend": "^6.12.2",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "migrate-mongo": "^14.0.7",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.0.2"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "_setup\\.js$"
    ]
  },
  "mongoms": {
    "useHttps": false
  }
}
