    "seed:english-questions-b": "node config/seedEnglishQuestionsB.js",
    "seed:english-questions-c": "node config/seedEnglishQuestionsC.js",
    "seed:english-questions-d": "node config/seedEnglishQuestionsD.js",
    "seed:english-topic-dag": "node config/seedEnglishTopicDAG.js",
    "seed:english-all": "node config/seedEnglishCurriculum.js && node config/seedEnglishNcertChapters.js && node config/seedEnglishContent.js && node config/seedEnglishQuestionsA.js && node config/seedEnglishQuestionsB.js && node config/seedEnglishQuestionsC.js && node config/seedEnglishQuestionsD.js && node config/seedEnglishTopicDAG.js"
