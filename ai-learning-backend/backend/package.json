    "seed:sst-content": "node config/seedSocialScienceContent.js",
    "seed:sst-history-content": "node config/seedSocialScienceHistoryContent.js",
    "seed:sst-geography-content": "node config/seedSocialScienceGeographyContent.js",
    "seed:sst-economics-content": "node config/seedSocialScienceEconomicsContent.js",
    "seed:sst-polsci-content": "node config/seedSocialSciencePolSciContent.js",
    "seed:sst-questions-a": "node config/seedSocialScienceQuestionsA.js",
    "seed:sst-questions-b": "node config/seedSocialScienceQuestionsB.js",
    "seed:sst-questions-c": "node config/seedSocialScienceQuestionsC.js",
    "seed:sst-topic-dag": "node config/seedSocialScienceTopicDAG.js",
    "seed:sst-ncert-chapters": "node config/seedSocialScienceNcertChapters.js",
    "seed:sst-missing-content": "node config/seedSocialScienceMissingContent.js",
    "seed:sst-missing-questions": "node config/seedSocialScienceMissingQuestions.js",
    "seed:sst-all": "node config/seedSocialScienceCurriculum.js && node config/seedSocialScienceNcertChapters.js && node config/seedSocialScienceHistoryContent.js && node config/seedSocialScienceGeographyContent.js && node config/seedSocialScienceEconomicsContent.js && node config/seedSocialSciencePolSciContent.js && node config/seedSocialScienceMissingContent.js && node config/seedSocialScienceQuestionsA.js && node config/seedSocialScienceQuestionsB.js && node config/seedSocialScienceQuestionsC.js && node config/seedSocialScienceMissingQuestions.js && node config/seedSocialScienceTopicDAG.js",
