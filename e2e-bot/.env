# ─────────────────────────────────────────────
#  AI Learning E2E Bot — environment settings
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Test account — bot will auto-register this user on first run
TEST_EMAIL=testbot@ailearning.dev
TEST_PASSWORD=TestBot@12345

# Where your frontend is running
FRONTEND_URL=http://localhost:5173

# Delay between actions in ms (higher = more visible / human-like)
SLOW_MO=400

# Set to true to run without opening a browser window (faster)
HEADLESS=false
