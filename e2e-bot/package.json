{
  "name": "ai-learning-e2e-bot",
  "version": "1.0.0",
  "description": "Human-like E2E bot — visits every page, clicks every button, reports issues per component",
  "type": "module",
  "scripts": {
    "test":          "playwright test --headed",
    "test:fast":     "playwright test --headed --workers=1",
    "test:debug":    "playwright test --headed --debug",
    "test:one":      "playwright test --headed --grep",
    "setup":         "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "cross-env":        "^7.0.3",
    "dotenv":           "^16.4.5"
  }
}
